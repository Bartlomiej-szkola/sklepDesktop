<Window x:Class="sklepDesktop.CardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Terminal Płatniczy" Height="300" Width="400" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Topmost="True" Background="#F0F0F0">
    <Border BorderThickness="5" BorderBrush="#007ACC" CornerRadius="10" Margin="10">
        <StackPanel VerticalAlignment="Center" Margin="20">
            <TextBlock Text="PŁATNOŚĆ KARTĄ" FontSize="32" FontWeight="ExtraBold" Foreground="#007ACC" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Name="LblAmount" Text="0,00 PLN" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Name="LblStatus" Text="Spójrz na terminal..." FontSize="18" FontWeight="Bold" Foreground="Orange" HorizontalAlignment="Center" Margin="0,15,0,0" TextWrapping="Wrap" TextAlignment="Center"/>

            <Button Name="BtnCancel" Content="Anuluj" Height="40" Width="120" Margin="0,20,0,0" Background="#DDDDDD" FontWeight="Bold" Click="BtnCancel_Click"/>
        </StackPanel>
    </Border>
</Window>