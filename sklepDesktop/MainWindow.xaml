<Window x:Class="sklepDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sklep WPF - Klient" Height="700" Width="1100" WindowState="Maximized" 
        Background="#F0F3F5" FontFamily="Segoe UI">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#455A64"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="4"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#37474F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,5,0,15"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#90A4AE"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="White"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="4"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#212121"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="0,0,0,2"/>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Foreground" Value="#546E7A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" BorderThickness="0,0,0,3" Margin="0,0,10,0">
                            <ContentPresenter x:Name="ContentSite" ContentSource="Header" Margin="12,2"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#1976D2"/>
                                <Setter Property="Foreground" Value="#1976D2"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontWeight="Bold" FontSize="16" Foreground="#212121" Margin="0,0,0,15"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.1" Color="Black"/>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Style.Resources>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CFD8DC"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="RowHeight" Value="38"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#ECEFF1"/>
                        <Setter Property="Foreground" Value="#212121"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="10,5"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="BorderBrush" Value="#CFD8DC"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <TabControl>
            <TabItem Header="Sprzedaż i Dodawanie">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="15" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="Skaner / Sprzedaż" Grid.Column="0">
                        <StackPanel Margin="5">
                            <Label Content="Zeskanuj kod kreskowy:"/>
                            <TextBox Name="TxtScan" Height="45" FontSize="20" FontWeight="Bold" KeyDown="TxtScan_KeyDown" BorderBrush="#1976D2" BorderThickness="2"/>
                            <Button Content="Szukaj (Manualnie)" Margin="0,-5,0,25" Height="35" Click="BtnSearch_Click"/>
                            <Border BorderBrush="#CFD8DC" BorderThickness="1" Padding="20" Background="#FFFDE7" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="Wynik skanowania:" FontWeight="Bold" Foreground="#546E7A" Margin="0,0,0,12"/>
                                    <TextBlock Name="LblResultName" Text="Nazwa: -" FontSize="22" Foreground="#212121" FontWeight="SemiBold"/>
                                    <TextBlock Name="LblResultPrice" Text="Cena: -" FontSize="40" FontWeight="Bold" Foreground="#1B5E20" Margin="0,8"/>
                                    <TextBlock Name="LblResultDesc" Text="Opis: -" FontStyle="Italic" Foreground="#424242" Margin="0,0,0,8"/>
                                    <TextBlock Name="LblResultStock" Text="Stan: -" Foreground="#212121" FontSize="14" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Dodaj nowy towar" Grid.Column="2">
                        <StackPanel Margin="5">
                            <Label Content="Kod kreskowy:"/>
                            <TextBox Name="TxtNewBarcode" Height="30" KeyDown="TxtNewBarcode_KeyDown"/>

                            <TextBlock Name="LblExternalStatus" Text="" Foreground="#E65100" FontSize="11" Margin="0,-12,0,12" FontWeight="SemiBold"/>
                            <Label Content="Nazwa:"/>
                            <TextBox Name="TxtNewName" Height="30"/>

                            <Label Content="Opis:"/>
                            <TextBox Name="TxtNewDesc" Height="30"/>

                            <Label Content="Cena (np. 12,99):"/>
                            <TextBox Name="TxtNewPrice" Height="30"/>

                            <Label Content="Ilość na stanie:"/>
                            <TextBox Name="TxtNewQty" Height="30"/>

                            <Button Content="ZAPISZ W BAZIE" Margin="0,15,0,0" Height="50" Click="BtnAdd_Click" Background="#1565C0" Foreground="White" FontSize="16" FontWeight="Bold"/>
                            <TextBlock Name="LblStatus" Foreground="#1976D2" Margin="0,15,0,0" TextWrapping="Wrap" TextAlignment="Center" FontWeight="Bold" FontSize="14"/>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="Edycja Produktu">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="15" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="Krok 1: Zeskanuj do edycji" Grid.Column="0" VerticalAlignment="Top">
                        <StackPanel Margin="5">
                            <Label Content="Zeskanuj kod towaru:"/>
                            <TextBox Name="TxtUpdateSearchBarcode" 
                                 Height="45" 
                                 FontSize="20" 
                                 FontWeight="Bold"
                                 KeyDown="TxtUpdateSearchBarcode_KeyDown" BorderBrush="#1976D2" BorderThickness="2"/>

                            <Border Margin="0,10,0,0" Padding="15" Background="#E3F2FD" BorderBrush="#90CAF9" BorderThickness="1" CornerRadius="6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="ℹ️" Margin="0,0,12,0" VerticalAlignment="Center" FontSize="16"/>
                                    <TextBlock Name="LblUpdateSearchStatus" 
                                           Text="Czekam na skanowanie..." 
                                           TextWrapping="Wrap" 
                                           FontSize="14" 
                                           Foreground="#1565C0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Krok 2: Edytuj dane" Grid.Column="2" Name="GroupEditFields" IsEnabled="False">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="5">
                                <Label Content="Nazwa produktu:"/>
                                <TextBox Name="TxtUpdateName" Height="30"/>

                                <Label Content="Opis:"/>
                                <TextBox Name="TxtUpdateDesc" Height="80" AcceptsReturn="True" TextWrapping="Wrap"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <Label Content="Cena (PLN):"/>
                                        <TextBox Name="TxtUpdatePrice" Height="30"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <Label Content="Ilość na stanie:"/>
                                        <TextBox Name="TxtUpdateQty" Height="30"/>
                                    </StackPanel>
                                </Grid>

                                <Button Content="ZAPISZ ZMIANY (Update)" Margin="0,25,0,10" Height="55" FontSize="17" Click="BtnUpdateSave_Click" Background="#2E7D32" Foreground="White" FontWeight="Bold"/>
                                <TextBlock Name="LblUpdateResult" FontSize="15" FontWeight="Bold" TextAlignment="Center" Margin="0,5,0,0"/>
                            </StackPanel>
                        </ScrollViewer>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="Dostawa (Przyjęcie)">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="15" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="Krok 1: Zeskanuj towar" Grid.Column="0" VerticalAlignment="Top">
                        <StackPanel Margin="5">
                            <Label Content="Kod kreskowy:"/>
                            <TextBox Name="TxtDeliveryBarcode" Height="45" FontSize="20" FontWeight="Bold" KeyDown="TxtDeliveryBarcode_KeyDown" BorderBrush="#1976D2" BorderThickness="2"/>

                            <Border Margin="0,10,0,0" Padding="15" Background="#F5F5F5" BorderBrush="#CFD8DC" BorderThickness="1" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Name="LblDeliveryProdName" Text="Produkt: -" FontSize="20" FontWeight="Bold" Foreground="#212121" Margin="0,0,0,8"/>
                                    <TextBlock Name="LblDeliveryCurrentStock" Text="Obecny stan: -" FontSize="15" Foreground="#424242" FontWeight="SemiBold"/>
                                    <TextBlock Name="LblDeliveryScanStatus" Text="Czekam na skan..." Margin="0,12,0,0" FontWeight="Bold" Foreground="#1976D2" FontSize="14"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Krok 2: Ilość dostawy" Grid.Column="2" Name="GroupDeliveryFields" IsEnabled="False">
                        <StackPanel Margin="5">
                            <Label Content="Liczba nowych sztuk:"/>
                            <TextBox Name="TxtDeliveryAmount" Height="70" FontSize="48" FontWeight="Bold" Margin="0,0,0,25" TextAlignment="Center" BorderBrush="#388E3C" BorderThickness="2.5" Foreground="#1B5E20"/>
                            <Button Content="ZATWIERDŹ DOSTAWĘ (+)" Height="65" FontSize="20" FontWeight="Bold" Background="#2E7D32" Foreground="White" Click="BtnDeliverySave_Click"/>
                            <TextBlock Name="LblDeliveryResult" FontSize="15" FontWeight="Bold" TextAlignment="Center" Margin="0,15,0,0"/>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="Kasa (POS)">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <DockPanel Grid.Column="0" Margin="0,0,15,0">
                        <GroupBox Header="Skanowanie towaru" DockPanel.Dock="Top" Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal" Margin="5">
                                <Label Content="KOD:" VerticalAlignment="Center" Margin="0,0,12,0" FontSize="16"/>
                                <TextBox Name="TxtCashierScan" Width="320" Height="50" FontSize="24" FontWeight="Bold" KeyDown="TxtCashierScan_KeyDown" BorderBrush="#1976D2" BorderThickness="2.5" Margin="0"/>
                                <TextBlock Name="LblCashierStatus" Text="Zeskanuj produkt..." VerticalAlignment="Center" Margin="25,0,0,0" Foreground="#607D8B" FontSize="15" FontWeight="SemiBold"/>
                            </StackPanel>
                        </GroupBox>

                        <DataGrid Name="DgBasket" AutoGenerateColumns="False" IsReadOnly="True" FontSize="17" ItemsSource="{Binding Basket}" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Nazwa" Binding="{Binding Name}" Width="*" />
                                <DataGridTextColumn Header="Cena" Binding="{Binding Price, StringFormat={}{0:C}}" Width="130" />
                                <DataGridTextColumn Header="Ilość" Binding="{Binding Quantity}" Width="90" />
                                <DataGridTextColumn Header="Suma" Binding="{Binding Total, StringFormat={}{0:C}}" Width="130" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>

                    <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="30">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.12" Color="Black"/>
                        </Border.Effect>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="DO ZAPŁATY" Foreground="#616161" HorizontalAlignment="Center" FontSize="18" FontWeight="Bold"/>
                            <TextBlock Name="LblTotalSum" Text="0,00 PLN" Foreground="#1B5E20" HorizontalAlignment="Center" FontSize="72" FontWeight="Bold" Margin="0,8,0,35"/>
                            <Button Content="PŁAĆ BLIK" Background="#D32F2F" Foreground="White" Height="60" FontSize="18" FontWeight="Bold" Margin="0,5" Click="BtnFinalizeSale_Click"/>
                            <Button Content="PŁAĆ KARTĄ" Background="#1976D2" Foreground="White" Height="60" FontSize="18" FontWeight="Bold" Margin="0,5" Click="BtnPayCard_Click"/>
                            <Separator Background="#CFD8DC" Margin="0,30"/>

                            <Button Content="USUŃ OSTATNI" Height="45" Margin="0,5" Click="BtnRemoveLast_Click" FontSize="14"/>
                            <Button Content="ANULUJ KOSZYK" Background="Transparent" BorderThickness="2" BorderBrush="#D32F2F" Foreground="#B71C1C" Height="45" Margin="0,5" Click="BtnClearBasket_Click" FontSize="14" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>