<Window x:Class="sklepDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sklep WPF - Klient" Height="450" Width="800">
    <Grid>
        <TabControl>
            <!-- ZAKŁADKA 1: OBSŁUGA I DODAWANIE (To co już masz) -->
            <TabItem Header="Sprzedaż i Dodawanie">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- LEWA STRONA: SKANOWANIE -->
                    <GroupBox Header="Skaner / Sprzedaż" Grid.Column="0">
                        <StackPanel Margin="10">
                            <Label Content="Zeskanuj kod kreskowy:" FontWeight="Bold"/>
                            <!-- KeyDown="TxtScan_KeyDown" to klucz do obsługi skanera! -->
                            <TextBox Name="TxtScan" Height="30" FontSize="16" KeyDown="TxtScan_KeyDown"/>

                            <Button Content="Szukaj (Manualnie)" Margin="0,5,0,20" Click="BtnSearch_Click"/>

                            <Border BorderBrush="Gray" BorderThickness="1" Padding="10" Background="#F0F0F0">
                                <StackPanel>
                                    <TextBlock Text="Wynik skanowania:" FontWeight="Bold"/>
                                    <TextBlock Name="LblResultName" Text="Nazwa: -" FontSize="18" Margin="0,10,0,0"/>
                                    <TextBlock Name="LblResultPrice" Text="Cena: -" FontSize="24" FontWeight="Bold" Foreground="Green"/>
                                    <TextBlock Name="LblResultDesc" Text="Opis: -" FontStyle="Italic"/>
                                    <TextBlock Name="LblResultStock" Text="Stan: -"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </GroupBox>

                    <!-- PRAWA STRONA: DODAWANIE -->
                    <GroupBox Header="Dodaj nowy towar" Grid.Column="2">
                        <StackPanel Margin="10">
                            <Label Content="Kod kreskowy:"/>
                            <TextBox Name="TxtNewBarcode" KeyDown="TxtNewBarcode_KeyDown"/>

                            <!-- Status pobierania z API zewnętrznego -->
                            <TextBlock Name="LblExternalStatus" Text="" Foreground="Orange" FontSize="10" Margin="0,2,0,5"/>

                            <Label Content="Nazwa:"/>
                            <TextBox Name="TxtNewName"/>

                            <Label Content="Opis:"/>
                            <TextBox Name="TxtNewDesc"/>

                            <Label Content="Cena (np. 12,99):"/>
                            <TextBox Name="TxtNewPrice"/>

                            <Label Content="Ilość na stanie:"/>
                            <TextBox Name="TxtNewQty"/>

                            <Button Content="Zapisz w bazie" Margin="0,20,0,0" Height="30" Background="#DDDDFF" Click="BtnAdd_Click"/>
                            <TextBlock Name="LblStatus" Foreground="Blue" Margin="0,10,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- ZAKŁADKA 2: AKTUALIZACJA PRODUKTU (Nowy Panel - układ dwukolumnowy) -->
            <TabItem Header="Edycja Produktu">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <!-- Kolumna lewa: Skanowanie -->
                        <ColumnDefinition Width="20" />
                        <!-- Odstęp między kolumnami -->
                        <ColumnDefinition Width="*" />
                        <!-- Kolumna prawa: Edycja danych -->
                    </Grid.ColumnDefinitions>

                    <!-- LEWA STRONA: SKANOWANIE DO EDYCJI -->
                    <GroupBox Header="Krok 1: Zeskanuj produkt do edycji" Grid.Column="0" VerticalAlignment="Top">
                        <StackPanel Margin="10">
                            <Label Content="Zeskanuj kod towaru:" FontWeight="Bold"/>
                            <TextBox Name="TxtUpdateSearchBarcode" 
                         Height="35" 
                         FontSize="18" 
                         VerticalContentAlignment="Center"
                         KeyDown="TxtUpdateSearchBarcode_KeyDown"/>

                            <Border Margin="0,15,0,0" Padding="10" Background="#FFF9F0" BorderBrush="#FFE4B5" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Name="LblUpdateSearchStatus" 
                                   Text="Czekam na skanowanie..." 
                                   TextWrapping="Wrap" 
                                   FontSize="14" 
                                   Foreground="Gray"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Wskazówka: Po zeskanowaniu dane pojawią się w panelu po prawej stronie." 
                           Margin="0,20,0,0" 
                           Foreground="DarkGray" 
                           FontStyle="Italic" 
                           TextWrapping="Wrap"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- PRAWA STRONA: FORMULARZ EDYCJI -->
                    <GroupBox Header="Krok 2: Edytuj dane produktu" 
                  Grid.Column="2" 
                  Name="GroupEditFields" 
                  IsEnabled="False">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="10">
                                <Label Content="Nazwa produktu:"/>
                                <TextBox Name="TxtUpdateName" Height="25" Margin="0,0,0,10"/>

                                <Label Content="Opis:"/>
                                <TextBox Name="TxtUpdateDesc" 
                             Height="60" 
                             AcceptsReturn="True" 
                             TextWrapping="Wrap" 
                             Margin="0,0,0,10"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <Label Content="Cena (PLN):"/>
                                        <TextBox Name="TxtUpdatePrice" Height="25"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <Label Content="Ilość na stanie:"/>
                                        <TextBox Name="TxtUpdateQty" Height="25"/>
                                    </StackPanel>
                                </Grid>

                                <Button Content="Zapisz zmiany (Update)" 
                            Margin="0,30,0,10" 
                            Height="45" 
                            FontSize="16"
                            FontWeight="Bold"
                            Background="#E1F5FE" 
                            Click="BtnUpdateSave_Click"/>

                                <TextBlock Name="LblUpdateResult" 
                               FontSize="14" 
                               FontWeight="Bold" 
                               TextAlignment="Center" 
                               Margin="0,5,0,0"/>
                            </StackPanel>
                        </ScrollViewer>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- ZAKŁADKA 3: DOSTAWY -->
            <TabItem Header="Dostawa (Przyjęcie)">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- LEWA STRONA: SKANOWANIE DOSTAWY -->
                    <GroupBox Header="Krok 1: Zeskanuj przywieziony towar" Grid.Column="0" VerticalAlignment="Top">
                        <StackPanel Margin="10">
                            <Label Content="Kod kreskowy:" FontWeight="Bold"/>
                            <TextBox Name="TxtDeliveryBarcode" Height="35" FontSize="18" VerticalContentAlignment="Center" KeyDown="TxtDeliveryBarcode_KeyDown"/>

                            <!-- STATUS SKANOWANIA (Zamiast MessageBox) -->
                            <Border Margin="0,15,0,0" Padding="15" Background="#F8F9FA" BorderBrush="#DEE2E6" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Name="LblDeliveryProdName" Text="Produkt: -" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
                                    <TextBlock Name="LblDeliveryCurrentStock" Text="Obecny stan: -" FontSize="14" Foreground="Gray"/>
                                    <TextBlock Name="LblDeliveryScanStatus" Text="Czekam na skan..." Margin="0,10,0,0" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </GroupBox>

                    <!-- PRAWA STRONA: ILOŚĆ DOSTAWY -->
                    <GroupBox Header="Krok 2: Ile sztuk dostarczono?" Grid.Column="2" Name="GroupDeliveryFields" IsEnabled="False">
                        <StackPanel Margin="10">
                            <Label Content="Liczba nowych sztuk:"/>
                            <TextBox Name="TxtDeliveryAmount" Height="40" FontSize="20" FontWeight="Bold" VerticalContentAlignment="Center" Margin="0,0,0,20"/>

                            <Button Content="Zatwierdź dostawę (+)" Height="50" FontSize="18" FontWeight="Bold" Background="#4CAF50" Foreground="White" Click="BtnDeliverySave_Click"/>

                            <!-- STATUS ZAPISU -->
                            <TextBlock Name="LblDeliveryResult" FontSize="14" FontWeight="Bold" TextAlignment="Center" Margin="0,15,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </TabItem>
			
			<!-- ZAKŁADKA 4 KASA-->
			<TabItem Header="Kasa (POS)">
				<Grid Margin="10">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="2*" />
						<!-- Lista produktów -->
						<ColumnDefinition Width="*" />
						<!-- Podsumowanie -->
					</Grid.ColumnDefinitions>

					<!-- LEWA STRONA: LISTA PRODUKTÓW (PARAGON) -->
					<DockPanel Grid.Column="0" Margin="0,0,10,0">
						<GroupBox Header="Skanowanie towaru" DockPanel.Dock="Top" Margin="0,0,0,10">
							<StackPanel Orientation="Horizontal" Margin="5">
								<Label Content="KOD:" VerticalAlignment="Center" FontWeight="Bold"/>
								<TextBox Name="TxtCashierScan" Width="300" Height="40" FontSize="20"
										 VerticalContentAlignment="Center" KeyDown="TxtCashierScan_KeyDown"/>
								<TextBlock Name="LblCashierStatus" Text="Zeskanuj produkt..."
										   VerticalAlignment="Center" Margin="15,0,0,0" Foreground="Gray"/>
							</StackPanel>
						</GroupBox>

						<DataGrid Name="DgBasket" AutoGenerateColumns="False" IsReadOnly="True" FontSize="16"
								  ItemsSource="{Binding Basket}">
							<DataGrid.Columns>
								<DataGridTextColumn Header="Nazwa" Binding="{Binding Name}" Width="*" />
								<DataGridTextColumn Header="Cena" Binding="{Binding Price, StringFormat={}{0:C}}" Width="100" />
								<DataGridTextColumn Header="Ilość" Binding="{Binding Quantity}" Width="80" />
								<DataGridTextColumn Header="Suma" Binding="{Binding Total, StringFormat={}{0:C}}" Width="100" />
							</DataGrid.Columns>
						</DataGrid>
					</DockPanel>

					<!-- PRAWA STRONA: PODSUMOWANIE -->
					<Border Grid.Column="1" Background="#222" CornerRadius="10" Padding="20">
						<StackPanel VerticalAlignment="Center">
							<TextBlock Text="DO ZAPŁATY" Foreground="White" HorizontalAlignment="Center" FontSize="20"/>
							<TextBlock Name="LblTotalSum" Text="0,00 PLN" Foreground="#00FF00"
									   HorizontalAlignment="Center" FontSize="48" FontWeight="Bold" Margin="0,10"/>

							<Button Content="ZATWIERDŹ I PŁAĆ" Height="80" FontSize="22" FontWeight="Bold"
									Background="#007ACC" Foreground="White" Margin="0,30,0,0"
									Click="BtnFinalizeSale_Click"/>

							<Button Content="USUŃ OSTATNI" Background="#444" Foreground="White"
									Margin="0,20,0,0" Click="BtnRemoveLast_Click"/>
							<Button Content="ANULUJ KOSZYK" Background="#600" Foreground="White"
									Margin="0,10,0,0" Click="BtnClearBasket_Click"/>
						</StackPanel>
					</Border>
				</Grid>
			</TabItem>

        </TabControl>
    </Grid>
    
    
    
</Window>